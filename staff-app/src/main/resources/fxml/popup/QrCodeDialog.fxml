<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane style="-fx-background-color: transparent;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.reservationsystem.controller.popup.QrCodeDialogController">
   <children>
      <VBox prefHeight="450.0" prefWidth="400.0" spacing="0" style="-fx-background-color: transparent; -fx-background-radius: 15;" stylesheets="@../../css/style.css">
          <children>
              <HBox alignment="CENTER_LEFT" prefHeight="50.0" prefWidth="400.0" spacing="10" style="-fx-background-color: #1976D2;" styleClass="message-dialog-header">
                  <children>
                      <Label style="-fx-font-size: 1.8em; -fx-text-fill: white;" text="📱" />
                      <Label style="-fx-font-size: 1.60em; -fx-font-weight: bold; -fx-text-fill: white;" text="Customer Registration QR" />
                  </children>
              </HBox>
              <VBox alignment="CENTER" prefHeight="400.0" prefWidth="400.0" spacing="15" styleClass="message-dialog-body" VBox.vgrow="ALWAYS">
                  <children>
                      <ImageView fx:id="qrImageView" fitHeight="250.0" fitWidth="250.0" pickOnBounds="true" preserveRatio="true" />
                      <Label fx:id="urlLabel" prefHeight="40.0" prefWidth="340.0" styleClass="message-dialog-label" text="https://reservationsystem-ul0w.onrender.com" wrapText="true">
                          <font>
                              <Font size="12.0" />
                          </font>
                      </Label>
                      <Label style="-fx-font-size: 1em; -fx-text-fill: #666;" text="Scan to register customers" />
                      <HBox alignment="CENTER" maxHeight="1.7976931348623157E308" prefHeight="50.0" prefWidth="340.0" spacing="15" VBox.vgrow="ALWAYS">
                          <children>
                              <Button fx:id="printBtn" maxHeight="1.7976931348623157E308" onAction="#onPrint" prefWidth="100.0" styleClass="button-confirm" text="Print" />
                              <Button fx:id="closeBtn" maxHeight="1.7976931348623157E308" onAction="#onClose" prefWidth="100.0" styleClass="button-cancel" text="Close" />
                          </children>
                      </HBox>
                  </children>
              </VBox>
          </children>
      </VBox>
   </children>
</StackPane>
