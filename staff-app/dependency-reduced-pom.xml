<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/maven-v4_0_0.xsd">
  <modelVersion>4.0.0</modelVersion>
  <groupId>com.mycompany</groupId>
  <artifactId>ReservationSystemFrontend</artifactId>
  <version>1.0-SNAPSHOT</version>
  <build>
    <plugins>
      <plugin>
        <artifactId>maven-compiler-plugin</artifactId>
        <version>3.8.0</version>
        <configuration>
          <release>21</release>
        </configuration>
      </plugin>
      <plugin>
        <artifactId>maven-shade-plugin</artifactId>
        <version>3.5.1</version>
        <executions>
          <execution>
            <phase>package</phase>
            <goals>
              <goal>shade</goal>
            </goals>
            <configuration>
              <transformers>
                <transformer>
                  <mainClass>com.mycompany.reservationsystem.App</mainClass>
                </transformer>
              </transformers>
            </configuration>
          </execution>
        </executions>
      </plugin>
      <plugin>
        <artifactId>maven-resources-plugin</artifactId>
        <version>3.3.1</version>
        <executions>
          <execution>
            <id>copy-jar-to-jpackage</id>
            <phase>package</phase>
            <goals>
              <goal>copy-resources</goal>
            </goals>
            <configuration>
              <outputDirectory>${project.build.directory}/jpackage-input</outputDirectory>
              <resources>
                <resource>
                  <directory>${project.build.directory}</directory>
                  <includes>
                    <include>${project.build.finalName}.jar</include>
                  </includes>
                </resource>
              </resources>
            </configuration>
          </execution>
          <execution>
            <id>copy-settings-to-jpackage</id>
            <phase>package</phase>
            <goals>
              <goal>copy-resources</goal>
            </goals>
            <configuration>
              <outputDirectory>${project.build.directory}/jpackage-input</outputDirectory>
              <resources>
                <resource>
                  <directory>${project.basedir}</directory>
                  <includes>
                    <include>settings.properties</include>
                  </includes>
                </resource>
              </resources>
            </configuration>
          </execution>
        </executions>
      </plugin>
      <plugin>
        <groupId>org.openjfx</groupId>
        <artifactId>javafx-maven-plugin</artifactId>
        <version>0.0.4</version>
      </plugin>
    </plugins>
  </build>
  <profiles>
    <profile>
      <id>jpackage</id>
      <build>
        <plugins>
          <plugin>
            <groupId>org.codehaus.mojo</groupId>
            <artifactId>exec-maven-plugin</artifactId>
            <version>3.5.0</version>
            <executions>
              <execution>
                <id>jpackage-app-image</id>
                <phase>verify</phase>
                <goals>
                  <goal>exec</goal>
                </goals>
                <configuration>
                  <executable>${env.JAVA_HOME}\bin\jpackage.exe</executable>
                  <arguments>
                    <argument>--type</argument>
                    <argument>app-image</argument>
                    <argument>--input</argument>
                    <argument>${project.build.directory}\jpackage-input</argument>
                    <argument>--dest</argument>
                    <argument>${project.build.directory}\jpackage-output</argument>
                    <argument>--name</argument>
                    <argument>ReservationSystem</argument>
                    <argument>--main-jar</argument>
                    <argument>${project.build.finalName}.jar</argument>
                    <argument>--module-path</argument>
                    <argument>${env.JAVA_HOME}\jmods</argument>
                    <argument>--add-modules</argument>
                    <argument>javafx.controls,javafx.fxml,java.net.http,jdk.crypto.ec,java.logging</argument>
                    <argument>--app-version</argument>
                    <argument>1.0</argument>
                    <argument>--vendor</argument>
                    <argument>Romantic Baboy</argument>
                    <argument>--description</argument>
                    <argument>ReservationSystem for Romantic Baboy</argument>
                    <argument>--icon</argument>
                    <argument>${project.basedir}\src\main\resources\Images\icon.ico</argument>
                    <argument>--java-options</argument>
                    <argument>-Dhttps.protocols=TLSv1.2,TLSv1.3</argument>
                    <argument>--java-options</argument>
                    <argument>-Djavax.net.ssl.trustStoreType=PKCS12</argument>
                    <argument>--java-options</argument>
                    <argument>-Djdk.tls.client.protocols=TLSv1.2,TLSv1.3</argument>
                    <argument>--java-options</argument>
                    <argument>-Djdk.tls.disabledAlgorithms=</argument>
                    <argument>--java-options</argument>
                    <argument>-Djdk.crypto.keygen.allowed=S</argument>
                  </arguments>
                </configuration>
              </execution>
            </executions>
          </plugin>
        </plugins>
      </build>
    </profile>
    <profile>
      <id>jpackage-exe</id>
      <build>
        <plugins>
          <plugin>
            <groupId>org.codehaus.mojo</groupId>
            <artifactId>exec-maven-plugin</artifactId>
            <version>3.5.0</version>
            <executions>
              <execution>
                <id>jpackage-exe</id>
                <phase>verify</phase>
                <goals>
                  <goal>exec</goal>
                </goals>
                <configuration>
                  <executable>${env.JAVA_HOME}\bin\jpackage.exe</executable>
                  <arguments>
                    <argument>--type</argument>
                    <argument>exe</argument>
                    <argument>--input</argument>
                    <argument>${project.build.directory}\jpackage-input</argument>
                    <argument>--dest</argument>
                    <argument>${project.build.directory}\jpackage-output</argument>
                    <argument>--name</argument>
                    <argument>ReservationSystem</argument>
                    <argument>--main-jar</argument>
                    <argument>${project.build.finalName}.jar</argument>
                    <argument>--module-path</argument>
                    <argument>${env.JAVA_HOME}\jmods</argument>
                    <argument>--add-modules</argument>
                    <argument>javafx.controls,javafx.fxml,java.net.http,jdk.crypto.ec,java.logging</argument>
                    <argument>--app-version</argument>
                    <argument>1.0</argument>
                    <argument>--vendor</argument>
                    <argument>Romantic Baboy</argument>
                    <argument>--description</argument>
                    <argument>ReservationSystem for Romantic Baboy</argument>
                    <argument>--icon</argument>
                    <argument>${project.basedir}\src\main\resources\Images\icon.ico</argument>
                    <argument>--java-options</argument>
                    <argument>-Dhttps.protocols=TLSv1.2,TLSv1.3</argument>
                    <argument>--java-options</argument>
                    <argument>-Djavax.net.ssl.trustStoreType=PKCS12</argument>
                    <argument>--java-options</argument>
                    <argument>-Djdk.tls.client.protocols=TLSv1.2,TLSv1.3</argument>
                    <argument>--java-options</argument>
                    <argument>-Djdk.tls.disabledAlgorithms=</argument>
                    <argument>--java-options</argument>
                    <argument>-Djdk.crypto.keygen.allowed=S</argument>
                    <argument>--win-dir-chooser</argument>
                    <argument>--win-menu</argument>
                    <argument>--win-shortcut</argument>
                  </arguments>
                </configuration>
              </execution>
            </executions>
          </plugin>
        </plugins>
      </build>
    </profile>
  </profiles>
  <properties>
    <maven.compiler.target>21</maven.compiler.target>
    <maven.compiler.source>21</maven.compiler.source>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
  </properties>
</project>
